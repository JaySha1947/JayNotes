# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Secret used to sign JWT session tokens. MUST be at least 32 characters.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If this changes, all existing sessions are invalidated (users must log in again).
JWT_SECRET=

# The public origin your users will open in their browser. Used for CORS.
# Examples:
#   http://localhost:3000             (local dev)
#   https://notes.example.com         (production behind Nginx + HTTPS)
ALLOWED_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Path on disk where the vault lives. Inside Docker this is /data and is
# bind-mounted from the host via docker-compose.yml. Outside Docker, set this
# to any absolute host path you want.
# VAULT_PATH=/data

# Max upload size in bytes. Default 50 MB.
# MAX_UPLOAD_SIZE=52428800

# Set to "false" to disable the iframe preview proxy entirely.
# ENABLE_IFRAME_PROXY=true

# Port the server listens on inside its process. In Docker, leave at 3000.
# PORT=3000
