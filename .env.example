# =============================================================================
# JayNotes — Environment Configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# Required: Secret used to sign JWT session tokens. MUST be at least 32 chars.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If this changes, all existing sessions are invalidated (users must log in again).
JWT_SECRET=

# The public origin your users will open in their browser. Used for CORS.
# Examples:
#   http://localhost:3000             (local dev — use this exact value)
#   https://notes.example.com         (production behind Nginx + HTTPS)
ALLOWED_ORIGIN=http://localhost:3000

# Optional: Path on disk where the vault lives.
# In Docker this is /data and is bind-mounted from the host.
# VAULT_PATH=/data

# Optional: Max upload size in bytes. Default 50 MB.
# MAX_UPLOAD_SIZE=52428800

# Optional: Set to "false" to disable the iframe preview proxy entirely.
# ENABLE_IFRAME_PROXY=true

# Optional: Port the server listens on inside its process.
# PORT=3000
